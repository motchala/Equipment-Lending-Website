DirectoryIndex landing-page.php

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"

    # Anti-clickjacking: X-Frame-Options (legacy browsers)
    Header always set X-Frame-Options "DENY"

    # CSP fallback: only set if PHP hasn't already sent one (PHP pages set their own nonce-based CSP)
    Header setifempty Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self';"

    Header unset Access-Control-Allow-Origin
    Header always unset Access-Control-Allow-Origin
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Fix: Cookie No HttpOnly Flag (ZAP)
    Header always edit Set-Cookie ^(.*)$ "$1; HttpOnly; SameSite=Strict"
</IfModule>

<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.cookie_path /
    php_value session.use_strict_mode 1
</IfModule>

<IfModule mod_php8.c>
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.cookie_path /
    php_value session.use_strict_mode 1
</IfModule>
